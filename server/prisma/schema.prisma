generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  leads        Lead[]
  activityLogs ActivityLog[]
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  permissions Permission[] @relation("RolePermissions")
  users       User[]
}

model Permission {
  id    Int    @id @default(autoincrement())
  name  String @unique // e.g., "manage_leads", "manage_users"
  roles Role[] @relation("RolePermissions")
}

model Lead {
  id              Int      @id @default(autoincrement())
  name            String
  email           String?
  email2          String?
  phone           String?
  phone2          String?
  source          String?
  type               String   @default("Manual")
  salesStage         String   @default("New")
  verificationStatus String   @default("Unverified")
  engagementStatus   String   @default("Not Engaged")
  consentStatus      String   @default("Unknown")
  registrationNo  String?
  contactPerson   String?
  address         String?
  city            String?
  state           String?
  pincode         String?
  userId          Int?
  user            User?         @relation(fields: [userId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  activityLogs    ActivityLog[]
  campaigns       Campaign[]
  consents        Consent[]
}

model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // EMAIL, SMS, WHATSAPP
  status    String   @default("DRAFT") // DRAFT, ACTIVE, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
  segmentId Int?
  segment   Segment? @relation(fields: [segmentId], references: [id])
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  content   String
  type      String   // EMAIL, SMS, WHATSAPP
  status    String   @default("PENDING") // PENDING, APPROVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Consent {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  channel   String   // EMAIL, SMS, WHATSAPP
  status    String   // OPT_IN, OPT_OUT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  leadId    Int?
  lead      Lead?    @relation(fields: [leadId], references: [id])
  action    String
  details   String?
  changes   String?  // JSON string or summary of old vs new values
  createdAt DateTime @default(now())
}

model Segment {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  rules       Json       // Stores conditions like { "region": "Maharashtra", "leadScore": { "gt": 80 } }
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  campaigns   Campaign[]
}
