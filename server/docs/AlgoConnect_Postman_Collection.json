{
  "info": {
    "name": "AlgoConnect API",
    "description": "Postman collection for AlgoConnect Backend APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:7700/health",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "7700",
          "path": [
            "health"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@algoconnect.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:7700/api/auth/login",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "7700",
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin\",\n  \"email\": \"admin@algoconnect.com\",\n  \"password\": \"password123\",\n  \"roleId\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:7700/api/auth/register",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "7700",
              "path": [
                "api",
                "auth",
                "register"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Get All Leads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:7700/api/leads",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "7700",
              "path": [
                "api",
                "leads"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Import Leads",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"leads\": [\n    { \"name\": \"Alice\", \"phone\": \"1111111111\" },\n    { \"name\": \"Bob\", \"email\": \"bob@example.com\" }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:7700/api/leads/import",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "7700",
              "path": [
                "api",
                "leads",
                "import"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    },
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          ""
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": "your_jwt_token_here",
      "type": "string"
    }
  ]
}
